# Normalize line endings to LF in the repository, checkout as-is on Windows
* text=auto eol=lf

# Force LF for scripts and config
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf

# Binaries — no transformation
*.pkl   binary
*.joblib binary
*.h5    binary
*.png   binary
*.jpg   binary
