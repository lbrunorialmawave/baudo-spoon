# ── PostgreSQL ────────────────────────────────────────────────────────────────
# REQUIRED — change before deploying to any shared or production environment
POSTGRES_PASSWORD=change_me_before_use

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Secret token required in X-API-Key header for /intelligence endpoints.
# Leave empty to disable authentication (dev/local only).
API_KEY_SECRET=

# Redis cache TTL for ML artifact responses (seconds).
API_CACHE_TTL_SECONDS=3600

# Sliding-window rate limit applied per client IP on /intelligence endpoints.
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_WINDOW_SECONDS=60

# ── Scraper (override defaults inside the container) ─────────────────────────
# SCRAPER_RETRIES=3
# SCRAPER_CACHE_DIR=/app/downloaded_files/cache
# SCRAPER_OUTPUT_DIR=/app/downloaded_files/output

# ── ML pipeline ───────────────────────────────────────────────────────────────
# ML_RANDOM_SEED=42
